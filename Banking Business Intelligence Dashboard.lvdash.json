{
  "datasets": [
    {
      "name": "business_summary",
      "displayName": "business_summary",
      "queryLines": [
        "SELECT\n",
        "  a.BRANCH_ID,\n",
        "  COUNT(*) AS total_transactions,\n",
        "  SUM(t.TRANSACTION_AMOUNT) AS total_revenue,\n",
        "  AVG(t.TRANSACTION_AMOUNT) AS avg_transaction\n",
        "FROM\n",
        "  workspace.default.silvertransactions t\n",
        "    JOIN workspace.default.silveraccounts a\n",
        "      ON t.ACCOUNT_ID = a.ACCOUNT_ID\n",
        "GROUP BY\n",
        "  a.BRANCH_ID"
      ]
    },
    {
      "name": "monthly_revenue_sql",
      "displayName": "monthly_revenue_sql",
      "queryLines": [
        "SELECT\n",
        "  date_format(t.TRANSACTION_DATE, 'yyyy-MM') AS month,\n",
        "  a.BRANCH_ID,\n",
        "  SUM(t.TRANSACTION_AMOUNT) AS revenue\n",
        "FROM\n",
        "  workspace.default.silvertransactions t\n",
        "    JOIN workspace.default.silveraccounts a\n",
        "      ON t.ACCOUNT_ID = a.ACCOUNT_ID\n",
        "GROUP BY\n",
        "  month,\n",
        "  a.BRANCH_ID\n",
        "ORDER BY\n",
        "  month DESC"
      ]
    },
    {
      "name": "top_customers",
      "displayName": "top_customers_by_spending",
      "queryLines": [
        "SELECT\n",
        "  a.CUSTOMER_ID,\n",
        "  a.BRANCH_ID,\n",
        "  SUM(t.TRANSACTION_AMOUNT) AS total_spent\n",
        "FROM\n",
        "  workspace.default.silvertransactions t\n",
        "    JOIN workspace.default.silveraccounts a\n",
        "      ON t.ACCOUNT_ID = a.ACCOUNT_ID\n",
        "GROUP BY\n",
        "  a.CUSTOMER_ID,\n",
        "  a.BRANCH_ID\n",
        "ORDER BY\n",
        "  total_spent DESC\n",
        "LIMIT 5"
      ]
    },
    {
      "name": "branch_revenue",
      "displayName": "branch_revenue",
      "queryLines": [
        "SELECT\n",
        "  a.BRANCH_ID,\n",
        "  SUM(t.TRANSACTION_AMOUNT) AS branch_revenue\n",
        "FROM\n",
        "  workspace.default.silvertransactions t\n",
        "    JOIN workspace.default.silveraccounts a\n",
        "      ON t.ACCOUNT_ID = a.ACCOUNT_ID\n",
        "GROUP BY\n",
        "  a.BRANCH_ID\n",
        "ORDER BY\n",
        "  branch_revenue DESC\n",
        "LIMIT 10"
      ]
    },
    {
      "name": "txn_type_analysis",
      "displayName": "transaction_type_analysis",
      "queryLines": [
        "SELECT\n",
        "  t.TRANSACTION_TYPE,\n",
        "  a.BRANCH_ID,\n",
        "  COUNT(*) AS txn_count,\n",
        "  SUM(t.TRANSACTION_AMOUNT) AS total_amount\n",
        "FROM\n",
        "  workspace.default.silvertransactions t\n",
        "    JOIN workspace.default.silveraccounts a\n",
        "      ON t.ACCOUNT_ID = a.ACCOUNT_ID\n",
        "GROUP BY\n",
        "  t.TRANSACTION_TYPE,\n",
        "  a.BRANCH_ID"
      ]
    },
    {
      "name": "monthly_txn_count",
      "displayName": "monthly_txn_count",
      "queryLines": [
        "SELECT\n",
        "  date_format(t.TRANSACTION_DATE, 'yyyy-MM') AS month,\n",
        "  a.BRANCH_ID,\n",
        "  COUNT(*) AS txn_count\n",
        "FROM\n",
        "  workspace.default.silvertransactions t\n",
        "    JOIN workspace.default.silveraccounts a\n",
        "      ON t.ACCOUNT_ID = a.ACCOUNT_ID\n",
        "GROUP BY\n",
        "  month,\n",
        "  a.BRANCH_ID\n",
        "ORDER BY\n",
        "  month DESC"
      ]
    },
    {
      "name": "high_risk_customers",
      "displayName": "high_risk_customers",
      "queryLines": [
        "SELECT\n",
        "  a.CUSTOMER_ID,\n",
        "  COUNT(*) AS txn_count,\n",
        "  SUM(t.TRANSACTION_AMOUNT) AS total_amount,\n",
        "  AVG(t.TRANSACTION_AMOUNT) AS avg_amount,\n",
        "  MAX(t.TRANSACTION_AMOUNT) AS max_amount,\n",
        "  ROUND(\n",
        "    (COUNT(*) * 0.3)\n",
        "      + (AVG(t.TRANSACTION_AMOUNT) / 1000 * 0.5)\n",
        "      + (SUM(t.TRANSACTION_AMOUNT) / 10000 * 0.2),\n",
        "    2\n",
        "  ) AS risk_score\n",
        "FROM\n",
        "  workspace.default.silvertransactions t\n",
        "    JOIN workspace.default.silveraccounts a\n",
        "      ON t.ACCOUNT_ID = a.ACCOUNT_ID\n",
        "GROUP BY\n",
        "  a.CUSTOMER_ID\n",
        "HAVING\n",
        "  COUNT(*) > 10\n",
        "  OR AVG(t.TRANSACTION_AMOUNT) > 60000\n",
        "ORDER BY\n",
        "  risk_score DESC\n",
        "LIMIT 5"
      ]
    },
    {
      "name": "customer_risk_scores",
      "displayName": "customer_risk_scores",
      "queryLines": [
        "SELECT\n",
        "  a.CUSTOMER_ID,\n",
        "  ROUND(\n",
        "    (COUNT(*) * 0.3)\n",
        "      + (AVG(t.TRANSACTION_AMOUNT) / 1000 * 0.5)\n",
        "      + (SUM(t.TRANSACTION_AMOUNT) / 10000 * 0.2),\n",
        "    2\n",
        "  ) AS Risk_Score,\n",
        "  COUNT(*) AS Txn_Count\n",
        "FROM\n",
        "  workspace.default.silvertransactions t\n",
        "    JOIN workspace.default.silveraccounts a\n",
        "      ON t.ACCOUNT_ID = a.ACCOUNT_ID\n",
        "GROUP BY\n",
        "  a.CUSTOMER_ID\n",
        "HAVING\n",
        "  COUNT(*) > 10\n",
        "  OR AVG(t.TRANSACTION_AMOUNT) > 60000\n",
        "ORDER BY\n",
        "  Risk_Score DESC\n",
        "LIMIT 10"
      ],
      "columns": [
        {
          "displayName": "Risk Category",
          "description": "Categorizes customers into High, Medium, or Low risk based on their risk score",
          "expression": "CASE WHEN `Risk_Score` >= 52 THEN 'High Risk' WHEN `Risk_Score` >= 50 THEN 'Medium Risk' ELSE 'Low Risk' END"
        }
      ]
    },
    {
      "name": "high_risk_count",
      "displayName": "high_risk_count",
      "queryLines": [
        "SELECT\n",
        "  COUNT(*) AS high_risk_customers\n",
        "FROM\n",
        "  (\n",
        "    SELECT\n",
        "      a.CUSTOMER_ID,\n",
        "      ROUND(\n",
        "        (COUNT(*) * 0.3)\n",
        "          + (AVG(t.TRANSACTION_AMOUNT) / 1000 * 0.5)\n",
        "          + (SUM(t.TRANSACTION_AMOUNT) / 10000 * 0.2),\n",
        "        2\n",
        "      ) AS Risk_Score\n",
        "    FROM\n",
        "      workspace.default.silvertransactions t\n",
        "        JOIN workspace.default.silveraccounts a\n",
        "          ON t.ACCOUNT_ID = a.ACCOUNT_ID\n",
        "    GROUP BY\n",
        "      a.CUSTOMER_ID\n",
        "  ) subquery\n",
        "WHERE\n",
        "  Risk_Score > 50"
      ]
    },
    {
      "name": "risk_kpis",
      "displayName": "risk_kpis",
      "queryLines": [
        "SELECT\n",
        "  SUM(total_amount) AS total_atrisk_amount,\n",
        "  AVG(Risk_Score) AS avg_risk_score,\n",
        "  COUNT(*) AS total_customers_monitored\n",
        "FROM\n",
        "  (\n",
        "    SELECT\n",
        "      a.CUSTOMER_ID,\n",
        "      SUM(t.TRANSACTION_AMOUNT) AS total_amount,\n",
        "      ROUND(\n",
        "        (COUNT(*) * 0.3)\n",
        "          + (AVG(t.TRANSACTION_AMOUNT) / 1000 * 0.5)\n",
        "          + (SUM(t.TRANSACTION_AMOUNT) / 10000 * 0.2),\n",
        "        2\n",
        "      ) AS Risk_Score\n",
        "    FROM\n",
        "      workspace.default.silvertransactions t\n",
        "        JOIN workspace.default.silveraccounts a\n",
        "          ON t.ACCOUNT_ID = a.ACCOUNT_ID\n",
        "    GROUP BY\n",
        "      a.CUSTOMER_ID\n",
        "    HAVING\n",
        "      COUNT(*) > 10\n",
        "      OR AVG(t.TRANSACTION_AMOUNT) > 60000\n",
        "  ) subquery\n",
        "WHERE\n",
        "  Risk_Score > 50"
      ]
    },
    {
      "name": "risk_distribution",
      "displayName": "risk_score_distribution",
      "queryLines": [
        "SELECT\n",
        "  ROUND(Risk_Score) AS risk_bucket,\n",
        "  COUNT(*) AS customer_count\n",
        "FROM\n",
        "  (\n",
        "    SELECT\n",
        "      a.CUSTOMER_ID,\n",
        "      ROUND(\n",
        "        (COUNT(*) * 0.3)\n",
        "          + (AVG(t.TRANSACTION_AMOUNT) / 1000 * 0.5)\n",
        "          + (SUM(t.TRANSACTION_AMOUNT) / 10000 * 0.2),\n",
        "        2\n",
        "      ) AS Risk_Score\n",
        "    FROM\n",
        "      workspace.default.silvertransactions t\n",
        "        JOIN workspace.default.silveraccounts a\n",
        "          ON t.ACCOUNT_ID = a.ACCOUNT_ID\n",
        "    GROUP BY\n",
        "      a.CUSTOMER_ID\n",
        "    HAVING\n",
        "      COUNT(*) > 10\n",
        "      OR AVG(t.TRANSACTION_AMOUNT) > 60000\n",
        "  ) subquery\n",
        "GROUP BY\n",
        "  risk_bucket\n",
        "ORDER BY\n",
        "  risk_bucket"
      ]
    }
  ],
